# MCPServer Environment Variables - Multi-Tenant Configuration
# Copy this file to .env and fill in your own values
# Never commit .env to version control!

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=development

# MCP API Security (use a strong, unique key)
MCP_API_KEY=your-mcp-api-key-here

# Server URL (used for OAuth redirects)
BASE_URL=http://localhost:3000

# Default organization (if org_id is not specified in requests)
DEFAULT_ORG=creative_shark

# ============================================================================
# Multi-Tenant: Organization Configuration
# ============================================================================
# Pattern: ORG_{ORGID}_{FIELD}
#
# Required fields for each organization:
#   - ORG_{ORGID}_ENABLED=true|false
#   - ORG_{ORGID}_NAME=Display name
#   - ORG_{ORGID}_SF_CLIENT_ID=Salesforce Connected App Client ID
#   - ORG_{ORGID}_SF_CLIENT_SECRET=Salesforce Connected App Secret
#
# Optional fields:
#   - ORG_{ORGID}_SF_LOGIN_URL=https://login.salesforce.com (default)
#   - ORG_{ORGID}_SF_API_VERSION=v65.0 (default)

# Example: Organization A (Production)
ORG_ORG_A_ENABLED=true
ORG_ORG_A_NAME=Organization A
ORG_ORG_A_SF_LOGIN_URL=https://login.salesforce.com
ORG_ORG_A_SF_CLIENT_ID=your-client-id-a
ORG_ORG_A_SF_CLIENT_SECRET=your-client-secret-a
ORG_ORG_A_SF_API_VERSION=v65.0

# Example: Organization B (Production)
ORG_ORG_B_ENABLED=true
ORG_ORG_B_NAME=Organization B
ORG_ORG_B_SF_LOGIN_URL=https://login.salesforce.com
ORG_ORG_B_SF_CLIENT_ID=your-client-id-b
ORG_ORG_B_SF_CLIENT_SECRET=your-client-secret-b
ORG_ORG_B_SF_API_VERSION=v65.0

# Example: Sandbox (disabled by default)
# ORG_SANDBOX_ENABLED=true
# ORG_SANDBOX_NAME=Sandbox
# ORG_SANDBOX_SF_LOGIN_URL=https://test.salesforce.com
# ORG_SANDBOX_SF_CLIENT_ID=your-sandbox-client-id
# ORG_SANDBOX_SF_CLIENT_SECRET=your-sandbox-client-secret
# ORG_SANDBOX_SF_API_VERSION=v65.0
