# MCPServer Environment Variables
# Copy this file to .env and fill in your own values
# Never commit .env to version control!

# Server Configuration
PORT=3000
NODE_ENV=development

# MCP API Security
MCP_API_KEY=your-mcp-api-key-here

# Salesforce OAuth Configuration
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your-salesforce-client-id
SF_CLIENT_SECRET=your-salesforce-client-secret

# Salesforce API
SF_API_VERSION=v65.0

# Server URL (used for OAuth redirect)
BASE_URL=http://localhost:3000

# Optional: Default organization (for multi-org setup)
# DEFAULT_ORG=org-a

# Optional: Multiple Organizations (for production)
# ORG_A_ENABLED=true
# ORG_A_NAME=Organization A
# ORG_A_SF_LOGIN_URL=https://login.salesforce.com
# ORG_A_SF_CLIENT_ID=your-client-id-a
# ORG_A_SF_CLIENT_SECRET=your-client-secret-a
# ORG_A_SF_API_VERSION=v65.0

# ORG_B_ENABLED=true
# ORG_B_NAME=Organization B
# ORG_B_SF_LOGIN_URL=https://login.salesforce.com
# ORG_B_SF_CLIENT_ID=your-client-id-b
# ORG_B_SF_CLIENT_SECRET=your-client-secret-b
# ORG_B_SF_API_VERSION=v65.0
